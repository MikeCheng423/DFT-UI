# Copy this file to `config.yaml` and edit the paths for your machine.
#   cp config.yaml.example config.yaml
# `config.yaml` is git-ignored so your local paths never get committed.

vasp_executable: /path/to/vasp.6.4.2/bin/vasp_std   # your VASP binary
jobs_root: /path/to/vasp_auto/jobs                  # where job folders are written
potcar_root: /path/to/POTCAR                         # your VASP POTCAR library (not shipped)
neb_images: 5

# DFT engine: "vasp" (default), "qe" (Quantum ESPRESSO, pw.x), or "ase" (any
# ASE calculator). Override per run with --engine, per project/case with a local
# config.yaml, or in the UI's engine dropdown. VASP needs a licence; QE is free.
engine: vasp

# Generic ASE-calculator engine (engine: ase). Runs any code ASE can drive on
# your structures; supports calc-types scf and relax. Needs the `ase` extra
# (pip install "vasp-auto[builder]" or "[local]"). The calculator's own binary,
# if any, is configured through ase_calc_params.
# ase_calculator: emt          # emt | lj | morse | espresso | gpaw | abinit |
#                              # castep | siesta | nwchem | vasp | mace
# ase_calc_params: {}          # kwargs passed to the calculator, e.g. for
#                              # Espresso: {pseudopotentials: {Si: Si.upf}, input_data: {...}}
#                              # Reach any calculator not listed above with the
#                              # special keys __module__ and __class__.
# ase_fmax: 0.05               # relax force tolerance (eV/A)
# ase_steps: 200               # relax: max optimizer steps
# ase_python:                  # python that runs the driver (default: the one
#                              # running vasp-auto)

# Quantum ESPRESSO settings (used when engine: qe or --engine qe):
qe_executable: /path/to/q-e/bin/pw.x   # path to the pw.x binary
pseudo_dir: /path/to/q-e/pseudo         # directory of .UPF pseudopotentials
pseudo_map:                             # pick a specific UPF per element
  Si: Si_ONCV_PBE-1.1.upf
# qe_ecutwfc: 50      # plane-wave cutoff (Ry)
# qe_ecutrho: 400     # charge-density cutoff (Ry; ~4x ecutwfc for NC, 8-12x for US/PAW)
# qe_conv_thr: 1.0e-6 # SCF convergence threshold (Ry)
# qe_degauss: 0.01    # smearing width (Ry)
# qe_smearing: gaussian

# Remote submission (used with `vasp-auto <target> --remote`).
# All input files (INCAR, KPOINTS, POSCAR, POTCAR, submit.sh) are copied to the
# remote machine and submitted to its queue over SSH, so this host can be turned
# off afterwards. Uncomment and edit:
#
# remote:
#   host: cluster.example.edu          # required: machine to submit to
#   user: myname                       # optional (else use ~/.ssh/config)
#   port: 22                           # optional SSH port
#   ssh_key: ~/.ssh/id_rsa             # optional private key
#   ssh_options: ["-o", "StrictHostKeyChecking=no"]   # optional extra ssh flags
#   remote_root: /scratch/myname/vasp_jobs   # required: base dir on the remote
#   vasp_executable: /opt/vasp/bin/vasp_std  # required: VASP path ON the remote
#   scheduler: slurm                   # slurm | pbs (default slurm)
#   scheduler_options:                 # optional extra submit-script lines
#     - "#SBATCH --partition=compute"
#     - "module load vasp"
#
# Several named machines (use with `vasp-auto <target> --remote NAME`). The web
# UI's Remote tab manages its own machines in remotes.json, but anything listed
# here also shows up there (read-only):
#
# remotes:
#   cluster1:
#     host: cluster.example.edu
#     user: myname
#     remote_root: /scratch/myname/vasp_jobs
#     vasp_executable: /opt/vasp/bin/vasp_std
#     scheduler: slurm
#   workstation:
#     host: 192.168.1.50
#     remote_root: /home/myname/runs
#     vasp_executable: /usr/local/bin/vasp_std
#     scheduler: slurm
